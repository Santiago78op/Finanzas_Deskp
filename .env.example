# Copiá este archivo como .env y llená tus valores reales.
# NUNCA subas el .env a ningún repositorio.

# Token de tu integración interna de Notion (empieza con "ntn_" o "secret_")
# Se crea en: https://www.notion.so/my-integrations
NOTION_TOKEN=

# ID de la página de Notion donde la app creará las bases de datos
# (Resumen del mes, Tarjetas, Alertas). Es la parte final de la URL de la página,
# 32 caracteres hexadecimales. Ej: si la URL es
# https://www.notion.so/Finanzas-1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c
# el ID es 1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c
NOTION_PARENT_PAGE_ID=
